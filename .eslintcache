ort About from './pages/About';\nimport Skills from './pages/Skills';\nimport Projects from './pages/Projects';\nimport Contact from './pages/Contact';\n\nfunction App() {\n  return (\n    <Router>\n      <NavigationBar/>\n      <Container fluid>\n        <Switch>\n          <Route path=\"/\" exact component={Home}/>\n          <Route path=\"/About\" component={About}/>\n          <Route path=\"/Skills\" component={Skills}/>\n          <Route path=\"/Projects\" component={Projects}/>\n          <Route path=\"/Contact\" component={Contact}/>\n        </Switch>\n      </Container>\n    </Router>\n  );\n}\n\nexport default App;\n","/Users/Steffano/Desktop/Programming/Projects/smalagadev.github.io/client/src/reportWebVitals.js",[],"/Users/Steffano/Desktop/Programming/Projects/smalagadev.github.io/client/src/pages/About/index.js",["55"],"import Row from 'react-bootstrap/Row';\nimport Col from 'react-bootstrap/Col';\n\nfunction About(){\n  return(\n    <>\n      <h1 className=\"card-title\">About Me</h1>\n      <Row>\n        <Col lg={6} md={12} sm={12} xs={12}>\n          <img src=\"assets/images/profile.jpg\" className=\"card-img\" id=\"profile-image\"/>\n        </Col>\n        <Col lg={6} md={12} sm={12} xs={12}>\n        <p className=\"card-text\">\n          A South Florida Native currently based in Atlanta, Georgia. I enjoy innovating solutions\n          and creating new technology. I enjoy problem solving\n          I have  experience with core web technologies with a focus on the MERN (Mongo, Express, React, and Node) stack.\n          Download my <a href=\"assets/Resume_Steffano_Malaga.pdf\" download id=\"resume\">resumé</a> to learn more about me.\n        </p>\n        </Col>\n      </Row>\n    </>\n  );\n}\n\nexport default About;\n","/Users/Steffano/Desktop/Programming/Projects/smalagadev.github.io/client/src/pages/Contact/index.js",["56","57","58"],"import './index.css';\nimport Card from 'react-bootstrap/Card';\nimport Button from 'react-bootstrap/Button';\nimport Row from 'react-bootstrap/Row';\nimport Col from 'react-bootstrap/Col';\nimport ListGroup from 'react-bootstrap/ListGroup';\nimport { IconContext } from \"react-icons\";\nimport { RiMailLine, RiSmartphoneLine, RiGithubLine, RiLinkedinBoxLine } from 'react-icons/ri';\n\nfunction Contact(){\n  const subject = \"We Want to Meet You!\";\n\n  return(\n    <Card>\n      <Row>\n      <Col lg={4} md={12} sm={12} xs={12}>\n        <Card.Img variant=\"top\" src=\"assets/images/profile.jpg\" />\n      </Col>\n      <Col lg={8} md={12} sm={12} xs={12}>\n        <Card.Body>\n          <Card.Title>Contact Me</Card.Title>\n          <Card.Text>\n            <p>\n              YOU CAN CONTACT MY EMAIL <RiMailLine/>:\n              <a target=\"_blank\" href={`https://mail.google.com/mail/u/0/?view=cm&fs=1&to=smalagadev@gmail.com&su=${subject}&tf=1`}>\n                SMALAGADEV@GMAIL.COM\n              </a>\n            </p>\n            <p>\n              YOU CAN REACH ME AT <RiSmartphoneLine/>: <a href=\"tel:9543192000\">9543192000</a>\n            </p>\n            <p>YOU CAN ALSO FIND ME ON THESE PLATFORMS:</p>\n            <ListGroup horizontal>\n              <ListGroup.Item>\n                  <a targer=\"_blank\" href=\"https://github.com/smalagadev\"><RiGithubLine/>GITHUB</a>\n              </ListGroup.Item>\n              <ListGroup.Item>\n                  <a targer=\"_blank\" href=\"https://linkedin.com/in/smalagadev\"><RiLinkedinBoxLine/>LINKEDIN</a>\n              </ListGroup.Item>\n            </ListGroup>\n          </Card.Text>\n        </Card.Body>\n      </Col>\n      </Row>\n    </Card>\n  );\n}\n\nexport default Contact;\n","/Users/Steffano/Desktop/Programming/Projects/smalagadev.github.io/client/src/pages/Projects/index.js",[],"/Users/Steffano/Desktop/Programming/Projects/smalagadev.github.io/client/src/components/ProjectTable/index.js",[],"/Users/Steffano/Desktop/Programming/Projects/smalagadev.github.io/client/src/components/ProjectRow/index.js",[],["59","60"],"/Users/Steffano/Desktop/Programming/Projects/smalagadev.github.io/client/src/components/NavigationBar/index.js",["61"],"import { Link } from 'react-router-dom';\nimport { RiToolsLine, RiHome2Line, RiCodeSSlashLine, RiUser3Line, RiChat4Line } from 'react-icons/ri';\nimport { IconContext } from 'react-icons';\nimport Navbar from 'react-bootstrap/Navbar';\nimport NavItem from 'react-bootstrap/NavItem';\nimport Nav from 'react-bootstrap/Nav';\nimport './index.css';\n\nexport default function NavigationBar(){\n  return(\n    <Navbar bg=\"dark\" variant=\"dark\" expand=\"lg\">\n      <Navbar.Brand><Link className=\"navbar-item\" to=\"/\">STEFFANO MALAGA</Link></Navbar.Brand>\n      <Navbar.Toggle aria-controls=\"basic-navbar-nav\" />\n      <Navbar.Collapse id=\"basic-navbar-nav\">\n        <Nav className=\"mr-auto flex-row\">\n          <Link to=\"/\" className=\"nav-link\" onMouseEnter>\n            <IconContext.Provider value={{ style: { verticalAlign: 'middle' }, className:'icon', attr: { 'data-hover': 'Home' } }}>\n              <RiHome2Line/> - Home\n            </IconContext.Provider>\n          </Link>\n          <Link to=\"/About\" className=\"nav-link\">\n            <IconContext.Provider value={{ style: { verticalAlign: 'middle' }, className:'icon', attr: { 'data-hover': 'About' } }}>\n              <RiUser3Line/> - About Me\n            </IconContext.Provider>\n          </Link>\n          <Link to=\"/Skills\" className=\"nav-link\">\n            <IconContext.Provider value={{ style: { verticalAlign: 'middle' }, className:'icon', attr: { 'data-hover': 'Skills' } }}>\n              <RiToolsLine/> - Skills\n            </IconContext.Provider>\n          </Link>\n          <Link to=\"/Projects\" className=\"nav-link\">\n            <IconContext.Provider value={{ style: { verticalAlign: 'middle' }, className:'icon', attr: { 'data-hover': 'Projects' } }}>\n              <RiCodeSSlashLine/> - Projects\n            </IconContext.Provider>\n          </Link>\n          <Link to=\"/Contact\" className=\"nav-link\">\n            <IconContext.Provider value={{ style: { verticalAlign: 'middle' }, className:'icon', attr: { 'data-hover': 'Contact' } }}>\n              <RiChat4Line/> - Contact Me\n            </IconContext.Provider>\n          </Link>\n        </Nav>\n      </Navbar.Collapse>\n    </Navbar>\n  );\n}\n","/Users/Steffano/Desktop/Programming/Projects/smalagadev.github.io/client/src/pages/Skills/index.js",[],"/Users/Steffano/Desktop/Programming/Projects/smalagadev.github.io/client/src/pages/Home/index.js",[],{"ruleId":"62","replacedBy":"63"},{"ruleId":"64","replacedBy":"65"},{"ruleId":"66","severity":1,"message":"67","line":1,"column":8,"nodeType":"68","messageId":"69","endLine":1,"endColumn":12},{"ruleId":"70","severity":1,"message":"71","line":10,"column":11,"nodeType":"72","endLine":10,"endColumn":89},{"ruleId":"66","severity":1,"message":"73","line":3,"column":8,"nodeType":"68","messageId":"69","endLine":3,"endColumn":14},{"ruleId":"66","severity":1,"message":"74","line":7,"column":10,"nodeType":"68","messageId":"69","endLine":7,"endColumn":21},{"ruleId":"75","severity":1,"message":"76","line":25,"column":18,"nodeType":"77","endLine":25,"endColumn":33},{"ruleId":"62","replacedBy":"78"},{"ruleId":"64","replacedBy":"79"},{"ruleId":"66","severity":1,"message":"80","line":5,"column":8,"nodeType":"68","messageId":"69","endLine":5,"endColumn":15},"no-native-reassign",["81"],"no-negated-in-lhs",["82"],"no-unused-vars","'logo' is defined but never used.","Identifier","unusedVar","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","'Button' is defined but never used.","'IconContext' is defined but never used.","react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","JSXAttribute",["81"],["82"],"'NavItem'